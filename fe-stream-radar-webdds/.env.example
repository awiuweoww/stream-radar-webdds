# --- Dashboard Configuration ---
# The port where the React application will run
SERVICE_PORT=3000
TARGET_PORT=3000

# Service metadata
SERVICE_NAME=radar-webdds
NODE_ENV=development

# --- WebDDS Connection ---
# The WebSocket URL of the Gateway Bridge. 
# Use ws://localhost:8080 for local docker development.
VITE_WEBDDS_URL=ws://localhost:8080/webdds
